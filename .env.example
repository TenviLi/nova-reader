# ─── Nova Reader Environment Configuration ─────────────────────────

# Server
NOVA_HOST=0.0.0.0
NOVA_PORT=3000
NOVA_ENV=development
NOVA_LOG_LEVEL=debug

# JWT Authentication
NOVA_JWT_SECRET=change-this-to-a-secure-random-string-in-production
NOVA_JWT_EXPIRY=7d

# PostgreSQL
POSTGRES_USER=nova
POSTGRES_PASSWORD=nova_secret_2024
POSTGRES_DB=nova_reader
DATABASE_URL=postgres://nova:nova_secret_2024@localhost:5432/nova_reader

# Redis
REDIS_URL=redis://localhost:6379

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=nova_graph_2024
NEO4J_URI=bolt://localhost:7687

# Meilisearch
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=nova_search_key_2024

# AI Services
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Embedding (Gitee AI - Qwen3-Embedding-4B)
EMBEDDING_MODEL=Qwen3-Embedding-4B
EMBEDDING_ENDPOINT=https://ai.gitee.com
EMBEDDING_API_KEY=your-gitee-ai-api-key
EMBEDDING_DIMENSIONS=2560

# Reranker (local vllm-mlx - Qwen3-Reranker-4B)
RERANKER_MODEL=Qwen3-Reranker-4B
RERANKER_ENDPOINT=http://127.0.0.1:8000

# File Ingestion
NOVA_INBOX_DIR=./data/inbox
NOVA_LIBRARY_DIR=./data/library
NOVA_DEBOUNCE_MS=500

# Worker Configuration
NOVA_WORKER_CONCURRENCY=8
NOVA_WORKER_RETRY_MAX=3
NOVA_WORKER_RETRY_DELAY_MS=5000
