{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            b.id as \"id!\",\n            b.title as \"title!\",\n            b.cover_path,\n            b.word_count as \"word_count!\",\n            bp.role::text as \"role!\"\n        FROM book_persons bp\n        JOIN books b ON b.id = bp.book_id\n        WHERE bp.person_id = $1\n        ORDER BY b.title\n        ",
