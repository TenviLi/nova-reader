{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT b.id, b.title, b.author, b.format, b.word_count, b.status, b.progress, b.cover_path\n        FROM books b\n        INNER JOIN shelf_books sb ON sb.book_id = b.id\n        WHERE sb.shelf_id = $1\n        ORDER BY sb.added_at DESC\n        ",
