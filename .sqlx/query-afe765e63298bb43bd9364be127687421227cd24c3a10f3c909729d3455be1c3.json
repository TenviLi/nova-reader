  "query": "SELECT a.selected_text, a.note, a.color, b.title as book_title, b.author as book_author\n           FROM annotation_shares s\n           JOIN annotations a ON a.id = s.annotation_id\n           JOIN books b ON b.id = a.book_id\n           WHERE s.token = $1",
