{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT l.id, l.name, l.root_path, l.description, l.auto_scan,\n               l.scan_interval_secs, l.include_extensions, l.exclude_patterns,\n               l.last_scan_at, l.last_scan_duration_ms, l.scan_status,\n               l.created_at, l.updated_at,\n               COUNT(DISTINCT s.id) as \"series_count!\",\n               COUNT(DISTINCT b.id) as \"book_count!\",\n               COALESCE(SUM(b.file_size), 0) as \"total_size_bytes!\"\n        FROM libraries l\n        LEFT JOIN series s ON s.library_id = l.id\n        LEFT JOIN books b ON b.series_id = s.id\n        GROUP BY l.id\n        ORDER BY l.name\n        ",
