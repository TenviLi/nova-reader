  "query": "\n        SELECT\n            id::text as \"id!\",\n            kind::text as \"kind!\",\n            status::text as \"status!\",\n            COALESCE(error_message, '') as \"error!\",\n            created_at::text as \"created_at!\"\n        FROM tasks\n        ORDER BY created_at DESC\n        LIMIT $1\n        ",
