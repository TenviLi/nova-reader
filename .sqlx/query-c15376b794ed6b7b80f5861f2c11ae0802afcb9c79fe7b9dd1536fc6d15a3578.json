{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT c.id, c.name, c.description, c.created_at, c.updated_at,\n               COUNT(cb.book_id) as \"book_count!\"\n        FROM collections c\n        LEFT JOIN collection_books cb ON cb.collection_id = c.id\n        WHERE c.id = $1\n        GROUP BY c.id\n        ",
