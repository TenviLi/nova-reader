{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT s.id, s.name, s.description, s.is_system,\n               COALESCE(COUNT(sb.book_id), 0) as \"book_count!\"\n        FROM shelves s\n        LEFT JOIN shelf_books sb ON sb.shelf_id = s.id\n        WHERE s.id = $1\n        GROUP BY s.id\n        ",
