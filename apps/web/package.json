  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && node ./scripts/ensure-paraglide-module.mjs && svelte-check --tsconfig ./tsconfig.json",
